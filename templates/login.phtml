    <script>
        const toggle = document.getElementById("toggle-register");
        const signupForm = document.getElementById("signup-form");
        const loginForm = document.getElementById("login-form");

        toggle.addEventListener("click", () => {
            if (signupForm.style.display === "none") {
                signupForm.style.display = "block";
                loginForm.style.display = "none"; // on cache le formulaire login
                toggle.textContent = "Se connecter"; // on change le texte
            } else {
                signupForm.style.display = "none";
                loginForm.style.display = "block"; // on réaffiche le login
                toggle.textContent = "Créer un compte"; // on remet le texte original
            }
        });
    </script>
